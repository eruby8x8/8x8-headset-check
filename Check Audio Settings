<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agent Audio Readiness Check — 8x8 Support</title>
  <meta name="description" content="Verify your headset and microphone are ready before going Available in 8x8 Agent Workspace." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── 8x8 Design Tokens ─────────────────────────────────── */
    :root {
      --grey:         #3A3A38;
      --off-white:    #EBEAE1;
      --white:        #FFFFFF;
      --teal-deep:    #04888A;
      --teal-light:   #8EBEB1;
      --green-deep:   #72AD6C;
      --green-vib:    #C9DC50;
      --orange:       #F37944;
      --red:          #C0392B;
      --amber:        #E6A817;
      --radius-sm:    8px;
      --radius-md:    14px;
      --radius-lg:    20px;
      --shadow-card:  0 2px 16px rgba(0,0,0,0.08);
      --shadow-hero:  0 8px 40px rgba(4,136,138,0.15);
      --transition:   0.2s ease;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Archivo', 'Segoe UI', Arial, sans-serif;
      background: var(--off-white);
      color: var(--grey);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAV ───────────────────────────────────────────────── */
    nav {
      background: var(--grey);
      padding: 0 32px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    /* 8x8 logotype built from text — matches brand */
    .logotype {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 22px;
      color: var(--white);
      letter-spacing: -0.5px;
      line-height: 1;
    }
    .logotype .x { color: var(--teal-light); }

    .nav-divider {
      width: 1px;
      height: 22px;
      background: rgba(255,255,255,0.25);
    }

    .nav-label {
      font-size: 13px;
      color: rgba(255,255,255,0.7);
      font-weight: 400;
      letter-spacing: 0.2px;
    }

    .nav-badge {
      font-size: 11.5px;
      background: var(--teal-deep);
      color: var(--white);
      padding: 3px 10px;
      border-radius: 20px;
      font-weight: 600;
    }

    /* ── HERO ──────────────────────────────────────────────── */
    .hero {
      background: linear-gradient(135deg, var(--grey) 0%, #2a2a28 100%);
      padding: 56px 32px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 60% 50%, rgba(4,136,138,0.18) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero-chip {
      display: inline-block;
      background: rgba(142,190,177,0.18);
      border: 1px solid rgba(142,190,177,0.4);
      color: var(--teal-light);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 20px;
      margin-bottom: 20px;
    }

    .hero h1 {
      font-size: clamp(26px, 5vw, 40px);
      font-weight: 700;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 14px;
      position: relative;
    }

    .hero h1 em {
      font-style: normal;
      color: var(--teal-light);
    }

    .hero p {
      font-size: 16px;
      color: rgba(255,255,255,0.72);
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.65;
      position: relative;
    }

    /* ── STEPS BANNER ──────────────────────────────────────── */
    .steps-bar {
      background: var(--white);
      border-bottom: 1px solid #ddd;
      padding: 18px 32px;
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
    }

    .step {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: #777;
    }

    .step-num {
      width: 24px; height: 24px;
      border-radius: 50%;
      background: var(--off-white);
      border: 2px solid #ccc;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      color: #999;
      flex-shrink: 0;
    }

    .step.active .step-num {
      background: var(--teal-deep);
      border-color: var(--teal-deep);
      color: var(--white);
    }
    .step.active { color: var(--grey); font-weight: 600; }

    .step-sep {
      color: #ccc;
      font-size: 18px;
      line-height: 1;
    }

    /* ── MAIN CONTENT ──────────────────────────────────────── */
    main {
      flex: 1;
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
      padding: 36px 20px 60px;
    }

    /* ── RESULT BANNER ─────────────────────────────────────── */
    #result-banner {
      display: none;
      border-radius: var(--radius-md);
      padding: 24px 26px;
      margin-bottom: 28px;
      box-shadow: var(--shadow-card);
    }

    #result-banner.ready {
      background: #edf7ed;
      border: 1.5px solid #72AD6C;
    }

    #result-banner.not-ready {
      background: #fdf0ef;
      border: 1.5px solid var(--red);
    }

    #result-banner.warning {
      background: #fffbec;
      border: 1.5px solid var(--amber);
    }

    .result-head {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }

    .result-icon {
      font-size: 28px;
      line-height: 1;
    }

    .result-title {
      font-size: 18px;
      font-weight: 700;
    }

    #result-banner p {
      font-size: 14px;
      line-height: 1.65;
      color: #444;
    }

    #result-banner ul {
      margin-top: 12px;
      padding-left: 20px;
    }

    #result-banner li {
      font-size: 13.5px;
      line-height: 1.75;
      color: #444;
    }

    /* ── CHECK CARDS ───────────────────────────────────────── */
    .checks {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 32px;
    }

    .check-card {
      background: var(--white);
      border-radius: var(--radius-md);
      padding: 18px 20px;
      box-shadow: var(--shadow-card);
      display: flex;
      align-items: flex-start;
      gap: 16px;
      border: 1.5px solid transparent;
      transition: border-color var(--transition);
    }

    .check-card.state-pass { border-color: rgba(114,173,108,0.4); }
    .check-card.state-fail { border-color: rgba(192,57,43,0.35); }
    .check-card.state-warn { border-color: rgba(230,168,23,0.4); }
    .check-card.state-spin { border-color: rgba(4,136,138,0.3); }

    .check-icon-wrap {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
      background: var(--off-white);
      transition: background var(--transition);
    }

    .state-pass .check-icon-wrap { background: #edf7ed; }
    .state-fail .check-icon-wrap { background: #fdf0ef; }
    .state-warn .check-icon-wrap { background: #fffbec; }
    .state-spin .check-icon-wrap { background: #e6f4f4; animation: softpulse 1.2s ease-in-out infinite; }

    @keyframes softpulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.55; }
    }

    .check-body { flex: 1; min-width: 0; }

    .check-title {
      font-size: 14.5px;
      font-weight: 700;
      margin-bottom: 4px;
      color: var(--grey);
    }

    .check-detail {
      font-size: 13px;
      color: #777;
      line-height: 1.5;
    }

    .check-detail.pass-text { color: #3d8b38; }
    .check-detail.fail-text { color: var(--red); }
    .check-detail.warn-text { color: #a07800; }

    /* Device tags */
    .device-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }

    .device-tag {
      font-size: 12px;
      padding: 3px 10px;
      border-radius: 20px;
      background: var(--off-white);
      color: #555;
      border: 1px solid #d5d4cb;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 220px;
    }

    .device-tag.active-tag {
      background: #e6f4f4;
      color: var(--teal-deep);
      border-color: rgba(4,136,138,0.4);
      font-weight: 600;
    }

    /* Meter */
    .meter-wrap {
      margin-top: 12px;
      background: #eee;
      border-radius: 6px;
      height: 8px;
      overflow: hidden;
    }

    .meter-bar {
      height: 100%;
      width: 0%;
      background: var(--teal-deep);
      border-radius: 6px;
      transition: width 0.08s linear;
    }

    .meter-subtext {
      font-size: 12px;
      color: #999;
      margin-top: 5px;
    }

    /* Timing bar */
    .timing-wrap {
      margin-top: 12px;
      background: #eee;
      border-radius: 6px;
      height: 8px;
      overflow: hidden;
    }

    .timing-bar {
      height: 100%;
      width: 0%;
      border-radius: 6px;
      transition: width 0.2s ease;
    }

    /* ── BUTTONS ───────────────────────────────────────────── */
    .btn-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 32px;
      border-radius: var(--radius-sm);
      font-family: inherit;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      border: 2px solid transparent;
      transition: all var(--transition);
      text-decoration: none;
    }

    .btn-primary {
      background: var(--teal-deep);
      color: var(--white);
      border-color: var(--teal-deep);
      box-shadow: 0 4px 14px rgba(4,136,138,0.3);
    }

    .btn-primary:hover:not(:disabled) {
      background: #036f71;
      box-shadow: 0 6px 18px rgba(4,136,138,0.4);
      transform: translateY(-1px);
    }

    .btn-primary:disabled {
      background: #b0b0ae;
      border-color: #b0b0ae;
      box-shadow: none;
      cursor: not-allowed;
      transform: none;
    }

    .btn-secondary {
      background: transparent;
      color: var(--grey);
      border-color: #c0bfb7;
      display: none;
    }

    .btn-secondary:hover {
      background: var(--grey);
      color: var(--white);
      border-color: var(--grey);
    }

    /* ── INFO BOX ──────────────────────────────────────────── */
    .info-box {
      background: var(--white);
      border-radius: var(--radius-md);
      padding: 20px 22px;
      margin-bottom: 28px;
      box-shadow: var(--shadow-card);
      border-left: 4px solid var(--teal-deep);
    }

    .info-box h2 {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 6px;
      color: var(--grey);
    }

    .info-box p {
      font-size: 13.5px;
      color: #666;
      line-height: 1.65;
    }

    /* ── FOOTER ────────────────────────────────────────────── */
    footer {
      background: var(--grey);
      color: rgba(255,255,255,0.5);
      text-align: center;
      padding: 22px 32px;
      font-size: 12.5px;
      line-height: 1.8;
    }

    footer a {
      color: var(--teal-light);
      text-decoration: none;
    }

    footer a:hover { text-decoration: underline; }

    .footer-logo {
      font-weight: 700;
      font-size: 15px;
      color: var(--white);
      margin-bottom: 4px;
    }

    /* ── RESPONSIVE ────────────────────────────────────────── */
    @media (max-width: 540px) {
      nav { padding: 0 18px; }
      .hero { padding: 40px 20px 36px; }
      .steps-bar { gap: 16px; padding: 14px 20px; }
      .step-sep { display: none; }
      main { padding: 24px 14px 48px; }
    }
  </style>
</head>
<body>

<!-- ── NAV ────────────────────────────────────────────────── -->
<nav>
  <a class="nav-logo" href="#">
    <span class="logotype">8<span class="x">x</span>8</span>
    <div class="nav-divider"></div>
    <span class="nav-label">Support</span>
  </a>
  <span class="nav-badge">Agent Tools</span>
</nav>

<!-- ── HERO ───────────────────────────────────────────────── -->
<div class="hero">
  <div class="hero-chip">Audio Readiness Check</div>
  <h1>Is Your Headset <em>Ready</em> to Take Calls?</h1>
  <p>Run this quick check before going Available in Agent Workspace. It takes under 30 seconds and helps prevent one-way audio on auto-answer calls.</p>
</div>

<!-- ── STEPS BAR ──────────────────────────────────────────── -->
<div class="steps-bar">
  <div class="step active">
    <div class="step-num">1</div>
    <span>Connect headset</span>
  </div>
  <div class="step-sep">›</div>
  <div class="step active">
    <div class="step-num">2</div>
    <span>Run checks below</span>
  </div>
  <div class="step-sep">›</div>
  <div class="step active">
    <div class="step-num">3</div>
    <span>Get your result</span>
  </div>
  <div class="step-sep">›</div>
  <div class="step active">
    <div class="step-num">4</div>
    <span>Go Available</span>
  </div>
</div>

<!-- ── MAIN ───────────────────────────────────────────────── -->
<main>

  <div class="info-box">
    <h2>Why does this matter?</h2>
    <p>Agent Workspace registers your softphone a few seconds before your browser finishes setting up your microphone. If a call arrives in that window via auto-answer, neither you nor the caller will hear audio. This tool confirms everything is ready before you go live.</p>
  </div>

  <!-- Result banner -->
  <div id="result-banner"></div>

  <!-- Check cards -->
  <div class="checks">

    <div class="check-card" id="card-permission">
      <div class="check-icon-wrap" id="icon-permission">🎙</div>
      <div class="check-body">
        <div class="check-title">Microphone Permission</div>
        <div class="check-detail" id="detail-permission">Click <strong>Run Checks</strong> to begin. Your browser will ask you to allow microphone access.</div>
      </div>
    </div>

    <div class="check-card" id="card-input">
      <div class="check-icon-wrap" id="icon-input">🎧</div>
      <div class="check-body">
        <div class="check-title">Audio Input Devices</div>
        <div class="check-detail" id="detail-input">Waiting…</div>
        <div class="device-tags" id="tags-input"></div>
      </div>
    </div>

    <div class="check-card" id="card-output">
      <div class="check-icon-wrap" id="icon-output">🔊</div>
      <div class="check-body">
        <div class="check-title">Audio Output Devices</div>
        <div class="check-detail" id="detail-output">Waiting…</div>
        <div class="device-tags" id="tags-output"></div>
      </div>
    </div>

    <div class="check-card" id="card-signal">
      <div class="check-icon-wrap" id="icon-signal">📶</div>
      <div class="check-body">
        <div class="check-title">Live Microphone Signal</div>
        <div class="check-detail" id="detail-signal">Waiting…</div>
        <div class="meter-wrap" id="meter-wrap" style="display:none;">
          <div class="meter-bar" id="meter-bar"></div>
        </div>
        <div class="meter-subtext" id="meter-subtext"></div>
      </div>
    </div>

    <div class="check-card" id="card-timing">
      <div class="check-icon-wrap" id="icon-timing">⏱</div>
      <div class="check-body">
        <div class="check-title">Device Readiness Speed</div>
        <div class="check-detail" id="detail-timing">Waiting…</div>
        <div class="timing-wrap" id="timing-wrap" style="display:none;">
          <div class="timing-bar" id="timing-bar"></div>
        </div>
      </div>
    </div>

  </div>

  <div class="btn-row">
    <button class="btn btn-primary" id="btn-run" onclick="runChecks()">
      ▶&nbsp; Run Checks
    </button>
    <button class="btn btn-secondary" id="btn-reset" onclick="resetAll()">
      ↺&nbsp; Run Again
    </button>
  </div>

</main>

<!-- ── FOOTER ─────────────────────────────────────────────── -->
<footer>
  <div class="footer-logo">8x8</div>
  <div>© 2026 8x8, Inc. All rights reserved. &nbsp;|&nbsp; <a href="https://support.8x8.com" target="_blank">support.8x8.com</a> &nbsp;|&nbsp; <a href="https://www.8x8.com/legal/privacy-policy" target="_blank">Privacy Policy</a></div>
</footer>

<!-- ── LOGIC ──────────────────────────────────────────────── -->
<script>
  let audioStream = null;
  let animFrame   = null;

  /* ── State helpers ──────────────────────────────────────── */
  function setState(id, state) {
    const card = document.getElementById('card-' + id);
    card.className = 'check-card' + (state ? ' state-' + state : '');
    const icon = document.getElementById('icon-' + id);
    const map = { permission:'🎙', input:'🎧', output:'🔊', signal:'📶', timing:'⏱' };
    const stateIcon = { pass:'✅', fail:'❌', warn:'⚠️', spin:'⏳' };
    icon.textContent = stateIcon[state] || map[id] || '●';
  }

  function setDetail(id, text, cls) {
    const el = document.getElementById('detail-' + id);
    el.innerHTML = text;
    el.className = 'check-detail' + (cls ? ' ' + cls + '-text' : '');
  }

  function setTags(id, devices) {
    const wrap = document.getElementById('tags-' + id);
    wrap.innerHTML = '';
    devices.forEach((d, i) => {
      const tag = document.createElement('span');
      tag.className = 'device-tag' + (i === 0 ? ' active-tag' : '');
      tag.title = d.label || `Device ${i+1}`;
      tag.textContent = (i === 0 ? '▶ ' : '') + (d.label || `Device ${i+1}`);
      wrap.appendChild(tag);
    });
  }

  /* ── Main runner ────────────────────────────────────────── */
  async function runChecks() {
    document.getElementById('btn-run').disabled = true;
    document.getElementById('btn-reset').style.display = 'none';
    document.getElementById('result-banner').style.display = 'none';

    const r = { permission: false, input: false, output: true, signal: false, timing: false };

    /* 1 — Mic permission */
    setState('permission', 'spin');
    setDetail('permission', 'Requesting microphone access…');

    const t0 = performance.now();
    try {
      audioStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
      const ms = Math.round(performance.now() - t0);
      setState('permission', 'pass');
      setDetail('permission', `Permission granted in <strong>${ms} ms</strong>.`, 'pass');
      r.permission = true;
    } catch (err) {
      setState('permission', 'fail');
      const msg = err.name === 'NotAllowedError'
        ? 'Permission denied. Click the <strong>🔒 lock icon</strong> in your browser address bar, set Microphone to <strong>Allow</strong>, then refresh and try again.'
        : `Could not access microphone: ${err.message}`;
      setDetail('permission', msg, 'fail');
      showResult(r); resetButton(); return;
    }

    /* 2 — Input devices */
    setState('input', 'spin');
    setDetail('input', 'Scanning audio input devices…');

    const t1 = performance.now();
    let allDevices = [];
    try { allDevices = await navigator.mediaDevices.enumerateDevices(); } catch(e) {}
    const enumMs = Math.round(performance.now() - t1);

    const inputs  = allDevices.filter(d => d.kind === 'audioinput');
    const outputs = allDevices.filter(d => d.kind === 'audiooutput');

    if (inputs.length === 0) {
      setState('input', 'fail');
      setDetail('input', 'No microphone or audio input device found. Connect a headset and run the check again.', 'fail');
    } else {
      setState('input', 'pass');
      setDetail('input', `<strong>${inputs.length}</strong> input device${inputs.length > 1 ? 's' : ''} detected. Active device shown in teal.`, 'pass');
      setTags('input', inputs);
      r.input = true;
    }

    /* 3 — Output devices */
    setState('output', 'spin');
    setDetail('output', 'Scanning audio output devices…');

    if (outputs.length === 0) {
      setState('output', 'warn');
      setDetail('output', 'No labeled output devices found. Audio may still route through your system default speaker.', 'warn');
    } else {
      setState('output', 'pass');
      setDetail('output', `<strong>${outputs.length}</strong> output device${outputs.length > 1 ? 's' : ''} detected.`, 'pass');
      setTags('output', outputs);
    }

    /* 4 — Live mic signal */
    setState('signal', 'spin');
    setDetail('signal', 'Listening for microphone signal — please speak or make a sound…');
    document.getElementById('meter-wrap').style.display = 'block';
    document.getElementById('meter-subtext').textContent = 'Speak into your mic…';

    let signalDetected = false;
    let peak = 0;

    const AudioCtx = window.AudioContext || window.webkitAudioContext;
    if (AudioCtx && audioStream) {
      const ctx = new AudioCtx();
      const src = ctx.createMediaStreamSource(audioStream);
      const an  = ctx.createAnalyser();
      an.fftSize = 256;
      src.connect(an);
      const buf = new Uint8Array(an.frequencyBinCount);
      const DURATION = 5000;

      await new Promise(resolve => {
        const start = performance.now();
        function tick() {
          an.getByteFrequencyData(buf);
          const avg = buf.reduce((a,b) => a+b, 0) / buf.length;
          const pct = Math.min(100, Math.round(avg / 255 * 400));
          peak = Math.max(peak, pct);
          const bar = document.getElementById('meter-bar');
          bar.style.width = pct + '%';
          bar.style.background = pct > 55 ? '#72AD6C' : pct > 20 ? '#04888A' : '#aaa';
          if (avg > 12) signalDetected = true;
          const left = Math.max(0, Math.ceil((DURATION - (performance.now() - start)) / 1000));
          document.getElementById('meter-subtext').textContent =
            `Input level: ${pct}% — ${left}s remaining`;
          if (performance.now() - start < DURATION)
            animFrame = requestAnimationFrame(tick);
          else resolve();
        }
        animFrame = requestAnimationFrame(tick);
      });
      cancelAnimationFrame(animFrame);
      ctx.close();
    }

    if (audioStream) { audioStream.getTracks().forEach(t => t.stop()); audioStream = null; }
    document.getElementById('meter-bar').style.width = '0%';

    if (signalDetected) {
      setState('signal', 'pass');
      setDetail('signal', `Live audio signal confirmed (peak level: <strong>${peak}%</strong>). Your mic is active and transmitting.`, 'pass');
      document.getElementById('meter-subtext').textContent = `Peak level recorded: ${peak}%`;
      r.signal = true;
    } else {
      setState('signal', 'warn');
      setDetail('signal', 'No audio signal detected in the 5-second window. Check that your mic is not muted and the correct input device is selected in Agent Workspace settings.', 'warn');
      document.getElementById('meter-subtext').textContent = 'No signal detected.';
    }

    /* 5 — Timing */
    setState('timing', 'spin');
    setDetail('timing', 'Measuring device readiness speed…');
    document.getElementById('timing-wrap').style.display = 'block';

    // Risk window is ~7000ms per VCC-183776 investigation
    const pct = Math.min(100, Math.round(enumMs / 7000 * 100));
    const tbar = document.getElementById('timing-bar');
    tbar.style.width = pct + '%';
    await new Promise(r => setTimeout(r, 300)); // let bar animate

    if (enumMs < 2000) {
      tbar.style.background = '#72AD6C';
      setState('timing', 'pass');
      setDetail('timing', `Devices enumerated in <strong>${enumMs} ms</strong> — well within the safe window.`, 'pass');
      r.timing = true;
    } else if (enumMs < 5000) {
      tbar.style.background = '#E6A817';
      setState('timing', 'warn');
      setDetail('timing', `Devices enumerated in <strong>${enumMs} ms</strong> — slightly slow. Wait 10–15 seconds after page load before going Available.`, 'warn');
      r.timing = true;
    } else {
      tbar.style.background = '#C0392B';
      setState('timing', 'fail');
      setDetail('timing', `Devices enumerated in <strong>${enumMs} ms</strong> — this exceeds the safe threshold. Restart your browser and run this check again before going Available.`, 'fail');
      r.timing = false;
    }

    showResult(r);
    resetButton();
  }

  /* ── Result banner ──────────────────────────────────────── */
  function showResult(r) {
    const b    = document.getElementById('result-banner');
    b.style.display = 'block';
    const pass = r.permission && r.input && r.output && r.signal && r.timing;
    const hard = !r.permission || !r.input;
    const fixes = [];

    if (!r.permission) fixes.push('Grant microphone permission — click the lock icon in your browser address bar, set Microphone to Allow, then refresh.');
    if (!r.input)      fixes.push('Connect a headset or USB microphone, then run the check again.');
    if (!r.signal)     fixes.push('Make sure your mic is not muted in Windows/macOS, and confirm the correct input device is selected in Agent Workspace audio settings.');
    if (!r.timing)     fixes.push('Your browser is slow to enumerate devices. Fully close and relaunch Chrome, then re-run this check before going Available.');

    if (pass) {
      b.className = 'ready';
      b.innerHTML = `
        <div class="result-head">
          <span class="result-icon">✅</span>
          <span class="result-title">You're good to go</span>
        </div>
        <p>All audio checks passed. Your headset is detected, microphone permission is granted, a live signal was confirmed, and your devices are ready within the safe window. You can safely set your status to <strong>Available</strong> in 8x8 Agent Workspace.</p>
      `;
    } else if (hard) {
      b.className = 'not-ready';
      b.innerHTML = `
        <div class="result-head">
          <span class="result-icon">❌</span>
          <span class="result-title">Not ready — do not go Available yet</span>
        </div>
        <p>One or more critical issues must be resolved before going Available to avoid one-way audio:</p>
        <ul>${fixes.map(f => `<li>${f}</li>`).join('')}</ul>
      `;
    } else {
      b.className = 'warning';
      b.innerHTML = `
        <div class="result-head">
          <span class="result-icon">⚠️</span>
          <span class="result-title">Proceed with caution</span>
        </div>
        <p>Some checks need attention. You may experience audio issues. Review the following before going Available:</p>
        <ul>${fixes.map(f => `<li>${f}</li>`).join('')}</ul>
        <p style="margin-top:12px; font-size:13px; color:#777;">If issues persist, submit feedback in Agent Workspace <strong>while on the affected call</strong> and share the Transaction ID with your 8x8 support contact.</p>
      `;
    }

    b.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function resetButton() {
    document.getElementById('btn-run').disabled = false;
    document.getElementById('btn-reset').style.display = 'inline-flex';
  }

  function resetAll() {
    cancelAnimationFrame(animFrame);
    if (audioStream) { audioStream.getTracks().forEach(t => t.stop()); audioStream = null; }

    ['permission','input','output','signal','timing'].forEach(id => {
      setState(id, null);
    });

    const defaults = {
      permission: 'Click <strong>Run Checks</strong> to begin. Your browser will ask you to allow microphone access.',
      input: 'Waiting…', output: 'Waiting…', signal: 'Waiting…', timing: 'Waiting…'
    };
    Object.keys(defaults).forEach(id => setDetail(id, defaults[id]));
    ['input','output'].forEach(id => { document.getElementById('tags-' + id).innerHTML = ''; });
    document.getElementById('meter-wrap').style.display   = 'none';
    document.getElementById('meter-bar').style.width      = '0%';
    document.getElementById('meter-subtext').textContent  = '';
    document.getElementById('timing-wrap').style.display  = 'none';
    document.getElementById('timing-bar').style.width     = '0%';
    document.getElementById('result-banner').style.display = 'none';
    document.getElementById('btn-reset').style.display    = 'none';
    document.getElementById('btn-run').disabled           = false;
  }
</script>
</body>
</html>
